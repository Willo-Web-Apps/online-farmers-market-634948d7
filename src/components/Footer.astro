---
const year = new Date().getFullYear();
---
<footer style="background-color: oklch(0.18 0.03 120); color: oklch(0.82 0.022 74);">
  <!-- Top wave from page -->
  <div style="line-height: 0;">
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block; width:100%; height:48px;">
      <path d="M0,24 C360,48 900,0 1440,24 L1440,0 L0,0 Z" fill="oklch(0.945 0.018 78)"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 sm:px-10 lg:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">

      <!-- Brand column -->
      <div class="md:col-span-2">
        <!-- Wordmark -->
        <div class="flex items-center gap-2.5 mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="color: oklch(0.72 0.115 52);">
            <path d="M12 2C6 2 3 7 3 12C3 17 6 20 12 20C18 20 21 16 21 10C21 6 18 2 12 2Z" fill="currentColor" fill-opacity="0.25"/>
            <path d="M12 20C12 20 8 16 8 12C8 8.5 10 5 12 4C14 5 16 8.5 16 12C16 16 12 20 12 20Z" fill="currentColor"/>
            <path d="M12 4C12 4 12 12 9 17" stroke="oklch(0.18 0.03 120)" stroke-width="1" stroke-linecap="round"/>
          </svg>
          <span class="font-display text-lg font-semibold" style="color: oklch(0.975 0.012 80);">Justin's Market</span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs" style="color: oklch(0.65 0.015 80);">
          Your farmers market, open every day. Connecting local growers with the people who love to eat well.
        </p>
        <!-- Social icons -->
        <div class="mt-6 flex gap-4">
          <a href="#" class="w-9 h-9 rounded-xl flex items-center justify-center transition-colors duration-150"
             style="background-color: oklch(0.28 0.03 120);"
             onmouseover="this.style.backgroundColor='oklch(0.38 0.09 140)'"
             onmouseout="this.style.backgroundColor='oklch(0.28 0.03 120)'">
            <!-- Instagram -->
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: oklch(0.82 0.022 74);">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-xl flex items-center justify-center transition-colors duration-150"
             style="background-color: oklch(0.28 0.03 120);"
             onmouseover="this.style.backgroundColor='oklch(0.38 0.09 140)'"
             onmouseout="this.style.backgroundColor='oklch(0.28 0.03 120)'">
            <!-- Facebook -->
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: oklch(0.82 0.022 74);">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: oklch(0.55 0.015 80); letter-spacing: 0.12em;">Shop</h4>
        <ul class="space-y-3">
          {['Vegetables & Greens', 'Fruit & Berries', 'Dairy & Eggs', 'Bread & Bakery', 'Honey & Preserves', 'Meat & Poultry'].map((item) => (
            <li><a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.65 0.015 80);" onmouseover="this.style.color='oklch(0.82 0.055 140)'" onmouseout="this.style.color='oklch(0.65 0.015 80)'">{item}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: oklch(0.55 0.015 80); letter-spacing: 0.12em;">Company</h4>
        <ul class="space-y-3">
          {['Our Story', 'For Farmers', 'Seasonal Guide', 'Stories & Recipes', 'Help Center', 'Contact Us'].map((item) => (
            <li><a href="#" class="text-sm transition-colors duration-150" style="color: oklch(0.65 0.015 80);" onmouseover="this.style.color='oklch(0.82 0.055 140)'" onmouseout="this.style.color='oklch(0.65 0.015 80)'">{item}</a></li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-14 pt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4" style="border-top: 1px solid oklch(0.26 0.025 100);">
      <p class="text-xs" style="color: oklch(0.45 0.012 80);">
        &copy; {year} Justin's Market, Inc. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs transition-colors duration-150" style="color: oklch(0.45 0.012 80);" onmouseover="this.style.color='oklch(0.65 0.015 80)'" onmouseout="this.style.color='oklch(0.45 0.012 80)'">Privacy Policy</a>
        <a href="#" class="text-xs transition-colors duration-150" style="color: oklch(0.45 0.012 80);" onmouseover="this.style.color='oklch(0.65 0.015 80)'" onmouseout="this.style.color='oklch(0.45 0.012 80)'">Terms of Service</a>
        <a href="#" class="text-xs transition-colors duration-150" style="color: oklch(0.45 0.012 80);" onmouseover="this.style.color='oklch(0.65 0.015 80)'" onmouseout="this.style.color='oklch(0.45 0.012 80)'">Accessibility</a>
      </div>
    </div>

  </div>
</footer>
